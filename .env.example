# ============================================================================
# OneDrive NAS backup — environment configuration
# Copy to ".env" and edit. NEVER commit the real .env (it holds your password).
# ============================================================================

# ---- REQUIRED -------------------------------------------------------------

# Host path on the HDD that will hold BOTH the live mirror and the restic repo.
# This single directory is mapped to /data inside the container.
# Layout created underneath it:
#   ${DATA_DIR}/mirror        <- live OneDrive mirror (~1 TB)
#   ${DATA_DIR}/restic-repo   <- deduplicated GFS version history
DATA_DIR=/mnt/hdd/onedrive-nas

# Restic repository password. This ENCRYPTS the version history.
# IF YOU LOSE THIS, THE VERSION HISTORY IS UNRECOVERABLE. Back it up in a
# password manager, separate from the HDD.
RESTIC_PASSWORD=change-me-to-a-long-random-passphrase

# Alternatively, point to a password file (mounted into the container) and
# leave RESTIC_PASSWORD unset:
# RESTIC_PASSWORD_FILE=/config/restic-password


# ---- rclone remote --------------------------------------------------------

# The rclone remote (created by scripts/setup-rclone.sh). Append a subpath to
# mirror only part of OneDrive, e.g. "onedrive:Documents". Trailing colon = root.
RCLONE_REMOTE=onedrive:

# rclone tuning — optimised for a single-spindle HDD.
# HDDs have one physical read/write head; concurrent transfers cause random
# seeking which destroys throughput. Use 1 transfer at a time for sequential
# access. A larger --buffer-size (16 M) lets rclone accumulate data and flush
# it in bigger sequential chunks, which suits HDD well.
# 16 M × 1 transfer = 16 MB RAM overhead — fine on a 1 GB Pi.
RCLONE_TRANSFERS=1
RCLONE_CHECKERS=2
RCLONE_TPSLIMIT=10
RCLONE_EXTRA_FLAGS=--buffer-size 16M
# Additional flags appended verbatim. Example: bandwidth cap.
# RCLONE_EXTRA_FLAGS=--buffer-size 16M --bwlimit 20M


# ---- Schedules ------------------------------------------------------------

# Seconds between mirror runs. 300 = every 5 min (near-real-time).
MIRROR_INTERVAL=300

# Seconds between restic snapshots. 86400 = once per day.
SNAPSHOT_INTERVAL=86400

# Set to 1 to run the mirror ONLY (no version history). Stage 1 alone still
# satisfies "never delete online-deleted files".
DISABLE_SNAPSHOTS=0


# ---- GFS retention (the version-history policy) ---------------------------
#
# This is the PRIMARY control for staying inside the HDD budget (see below).
# Meaning: keep the most recent snapshot from each of the last N days/weeks/
# months. With deduplication, total repo size ~= unique data + churn, NOT
# N x full size.
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
KEEP_YEARLY=0     # 0 disables yearly retention

RESTIC_HOST=onedrive-nas
RESTIC_TAG=onedrive

# Larger pack files → fewer packs → smaller in-memory index during backup/prune.
# On an HDD, larger packs also mean fewer but bigger sequential writes, which
# suits a spinning disk. 256 MB is a good balance; 128 MB is restic's default.
RESTIC_PACK_SIZE=256

# Run the full forget --prune only every N snapshots, not after every daily backup.
# Prune is the most memory-hungry restic operation. 7 = prune once per week on a
# daily snapshot schedule. Set to 1 to prune after every snapshot (original behaviour).
PRUNE_EVERY_N=7


# ---- Disk safety guard ----------------------------------------------------
#
# The orchestrator checks /data usage. At/above HALT it SKIPS snapshots to
# avoid filling the disk (a full disk breaks both rclone writes and restic
# prune). At/above WARN it logs a warning to tighten retention.
# Variable names are intentionally disk-type-agnostic (DISK_ not SSD_).
DISK_USAGE_WARN_PCT=85
DISK_USAGE_HALT_PCT=92


# ---- Resource limits & misc ----------------------------------------------

TZ=Europe/Berlin
# Hard RAM cap for the container. Keep below ~500 MB so the OS and Docker
# daemon keep their share of the ~600 MB available on a 1 GB Pi.
MEM_LIMIT=512m
# Total RAM+swap the container may use. WARNING: swap on a spinning HDD is
# 10-100× slower than on an SSD. If restic prune pages into HDD swap it will
# stall for hours. Prefer a Pi with enough RAM (4 GB+) rather than relying on
# swap. If swap is unavoidable, keep it small or put it on a USB stick/SD slot.
MEM_SWAP_LIMIT=2048m
CPU_LIMIT=1.5
LOG_LEVEL=INFO

# ============================================================================
# STORAGE BUDGET — 1 TB OneDrive source, 2 TB HDD
# ============================================================================
#
#   2 TB HDD
#   ├── mirror/        ~1 TB now, grows slowly as online-deleted files are kept
#   └── restic-repo/   deduplicated version history (the rest of the budget)
#
# Target: mirror + repo must stay well under 2 TB. Keep the repo under roughly
# 600-800 GB to leave headroom (the mirror itself is ~1 TB + retained
# deletions). The KEEP_* values above are deliberately CONSERVATIVE
# (keep-monthly 6, no yearly) to fit a 2 TB disk.
#
# Procedure:
#   - Run for a few weeks, then: ./scripts/admin.sh stats
#   - If you have comfortable headroom, raise KEEP_MONTHLY toward 12 and/or
#     set KEEP_YEARLY=1-2.
#   - If usage climbs toward ~1.6-1.7 TB, REDUCE retention (lower KEEP_MONTHLY,
#     drop KEEP_WEEKLY to 2). It's much easier to add history than to recover
#     from a full disk.
# ============================================================================
