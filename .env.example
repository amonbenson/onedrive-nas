# ============================================================================
# OneDrive NAS backup — environment configuration
# Copy to ".env" and edit. NEVER commit the real .env (it holds your password).
# ============================================================================

# ---- REQUIRED -------------------------------------------------------------

# Host path on the HDD that will hold BOTH the live mirror and the restic repo.
# This single directory is mapped to /data inside the mirror container, and
# its subdirectories are mounted individually into the backrest container.
# Layout created underneath it:
#   ${DATA_DIR}/mirror        <- live OneDrive mirror (~1 TB)
#   ${DATA_DIR}/restic-repo   <- deduplicated GFS version history (backrest-owned)
DATA_DIR=/mnt/hdd/onedrive-nas


# ---- Backrest (owns all restic writes: backup/forget/prune) ---------------

# Restic repository password. This ENCRYPTS the version history.
# IF YOU LOSE THIS, THE VERSION HISTORY IS UNRECOVERABLE. Back it up in a
# password manager, separate from the HDD.
#
# This value is NOT read automatically by backrest at runtime — paste it once
# into the Backrest UI's "Password" field when adding the repository (see
# README). It's kept here as your canonical record of the password and so
# it's available as a container env var for convenient copy-paste
# (`docker compose exec backrest sh -c 'echo $RESTIC_PASSWORD'`).
RESTIC_PASSWORD=change-me-to-a-long-random-passphrase


# ---- rclone remote --------------------------------------------------------

# The rclone remote (created by scripts/setup-rclone.sh). Append a subpath to
# mirror only part of OneDrive, e.g. "onedrive:Documents". Trailing colon = root.
RCLONE_REMOTE=onedrive:

# rclone tuning — optimised for a single-spindle HDD.
# HDDs have one physical read/write head; concurrent transfers cause random
# seeking which destroys throughput. Use 1 transfer at a time for sequential
# access. A larger --buffer-size (16 M) lets rclone accumulate data and flush
# it in bigger sequential chunks, which suits HDD well.
# 16 M × 1 transfer = 16 MB RAM overhead — fine on a 1 GB Pi.
RCLONE_TRANSFERS=1
RCLONE_CHECKERS=2
RCLONE_TPSLIMIT=10
RCLONE_EXTRA_FLAGS=--buffer-size 16M
# Additional flags appended verbatim. Example: bandwidth cap.
# RCLONE_EXTRA_FLAGS=--buffer-size 16M --bwlimit 20M


# ---- Schedules ------------------------------------------------------------

# Seconds between mirror runs. 300 = every 5 min (near-real-time).
MIRROR_INTERVAL=300

# Restic backup/retention/prune schedules are no longer configured here — set
# them in the Backrest UI (cron schedule per plan, plus a separate prune/check
# schedule on the repository). See README.


# ---- Disk safety guard (mirror only) ---------------------------------------
#
# The mirror container checks /data usage and logs a warning at/above this
# percentage so you know to tighten Backrest's retention policy before the
# disk fills. It does not halt the mirror — rclone/restic will surface their
# own errors if the disk actually fills up.
DISK_USAGE_WARN_PCT=85


# ---- Resource limits & misc ----------------------------------------------

TZ=Europe/Berlin

# onedrive-nas (mirror) container. It only runs rclone now (no more in-process
# restic prune), so it needs much less headroom than before.
MEM_LIMIT=256m
MEM_SWAP_LIMIT=1024m
CPU_LIMIT=1.0

# backrest container. Sized to comfortably cover restic backup/prune — the
# heaviest operations now live here. Capping it means a worst-case overlap
# with a concurrent rclone sync (there's no shared lock between the two
# containers anymore) OOM-kills only this container, auto-recovered by
# `restart: unless-stopped`, rather than risking the whole Pi.
BACKREST_MEM_LIMIT=320m
BACKREST_MEM_SWAP_LIMIT=1280m
BACKREST_CPU_LIMIT=1.0

LOG_LEVEL=INFO

# ============================================================================
# STORAGE BUDGET — 1 TB OneDrive source, 2 TB HDD
# ============================================================================
#
#   2 TB HDD
#   ├── mirror/        ~1 TB now, grows slowly as online-deleted files are kept
#   └── restic-repo/   deduplicated version history (the rest of the budget)
#
# Target: mirror + repo must stay well under 2 TB. Keep the repo under roughly
# 600-800 GB to leave headroom (the mirror itself is ~1 TB + retained
# deletions). Configure retention (keep-daily/weekly/monthly/yearly) in the
# Backrest UI's repository "Forget Policy" (retention is repo-level, not
# per-plan) — start CONSERVATIVE (e.g. daily 7 / weekly 4 / monthly 6, no
# yearly) to fit a 2 TB disk.
#
# Procedure:
#   - Run for a few weeks, then check repo size in the Backrest UI's
#     repository stats view.
#   - If you have comfortable headroom, raise the monthly retention and/or
#     add yearly retention.
#   - If usage climbs toward ~1.6-1.7 TB, REDUCE retention in the repository's
#     Forget Policy (lower monthly, drop weekly to 2). It's much easier to
#     add history than to recover from a full disk.
# ============================================================================
